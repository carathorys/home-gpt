<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:home_gpt.Avalonia.Views"
        xmlns:vm="using:home_gpt.Avalonia.ViewModels"
        x:Class="home_gpt.Avalonia.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="home-gpt"
        Width="1100"
        Height="720"
        MinWidth="900"
        MinHeight="600">
  <DockPanel Margin="12">
    <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,12">
      <TextBlock Text="home-gpt" FontSize="24" FontWeight="Bold" />
      <TextBlock Text="TorchSharp character-level word model" Opacity="0.7" />
      <TextBlock Text="{Binding DeviceStatus}" />
    </StackPanel>

    <TabControl SelectedIndex="{Binding SelectedTabIndex}">
      <TabItem Header="Train model">
        <views:TrainingView DataContext="{Binding Training}" />
      </TabItem>
      <TabItem Header="Generate words">
        <views:GenerationView DataContext="{Binding Generation}" />
      </TabItem>
    </TabControl>
  </DockPanel>
</Window>
